PORT=3003
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
FRONTEND_ORIGIN=http://localhost:5173
# F8 — seconds before a PENDING request becomes TIMED_OUT (default 60; use e.g. 10 for quick local tests)
MATCH_TIMEOUT_SECONDS=60
# F9 — seconds to reconnect after disconnect while waiting (default 30; use e.g. 10 for local tests)
RECONNECT_GRACE_SECONDS=30
